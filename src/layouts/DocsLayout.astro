---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "llm-contract documentation" } = Astro.props;
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Overview" },
  { href: "/quickstart", label: "Quickstart" },
  { href: "/how-it-works", label: "How It Works" },
  { href: "/api", label: "API" },
  { href: "/failure-model", label: "Failure Model" },
  { href: "/observability", label: "Observability" },
  { href: "/examples", label: "Examples" },
];

const isActive = (href: string): boolean => {
  if (href === "/") {
    return pathname === "/";
  }
  return pathname.startsWith(href);
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        darkMode: "class",
      };
    </script>
    <style is:global>
      :root {
        color-scheme: dark;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: radial-gradient(circle at top, #111827 0%, #020617 35%, #020617 100%);
        color: #e2e8f0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
      }

      a {
        color: inherit;
      }

      .text-accent {
        color: #60a5fa;
      }

      .text-accent-blue {
        color: #93c5fd;
      }

      .bg-surface {
        background: rgba(15, 23, 42, 0.75);
      }

      .border-border {
        border-color: rgba(148, 163, 184, 0.28);
      }

      .glass {
        background: rgba(15, 23, 42, 0.42);
        border: 1px solid rgba(148, 163, 184, 0.2);
        backdrop-filter: blur(10px);
      }

      .card-hover {
        transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
      }

      .card-hover:hover {
        transform: translateY(-2px);
        border-color: rgba(96, 165, 250, 0.48);
        background: rgba(30, 41, 59, 0.55);
      }

      .gradient-text {
        background: linear-gradient(90deg, #ffffff 0%, #93c5fd 45%, #60a5fa 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      pre {
        margin: 0;
        overflow-x: auto;
        font-size: 0.875rem;
        line-height: 1.6;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      }
    </style>
  </head>
  <body class="min-h-screen text-zinc-200">
    <header class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/75 backdrop-blur">
      <div class="max-w-6xl mx-auto px-6 py-4">
        <div class="flex flex-wrap gap-3 items-center justify-between">
          <a href="/" class="font-semibold tracking-tight text-zinc-100">llm-contract</a>
          <nav class="flex flex-wrap gap-2 text-sm text-zinc-300">
            {
              links.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    "rounded-md px-3 py-1.5 border transition",
                    isActive(link.href)
                      ? "border-blue-400/40 bg-blue-400/10 text-blue-200"
                      : "border-transparent hover:border-white/15 hover:bg-white/5",
                  ]}
                >
                  {link.label}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
