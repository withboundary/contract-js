---
import DocsLayout from "../layouts/DocsLayout.astro";
---

<DocsLayout title="Failure Model — llm-contract" description="Failure categories, default repair behavior, repair overrides, and retry policy interactions.">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-12">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight"><span class="gradient-text">Failure Model</span></h1>
    <p class="text-zinc-400 text-lg max-w-3xl">
      llm-contract classifies each failed attempt and generates category-aware repair feedback.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-6 tracking-tight">Failure categories</h2>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">type FailureCategory =
  | "EMPTY_RESPONSE"
  | "REFUSAL"
  | "NO_JSON"
  | "TRUNCATED"
  | "PARSE_ERROR"
  | "VALIDATION_ERROR"
  | "INVARIANT_ERROR"
  | "RUN_ERROR";</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-6 tracking-tight">Repair behavior</h2>
    <p class="text-zinc-400 max-w-3xl mb-6">
      By default, each category maps to a targeted repair message. Validation and invariant errors include issue lists.
    </p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">const issueList = detail.issues.map((issue) => `- &#36;&#123;issue&#125;`).join("\\n");
return [&#123;
  role: "user",
  content: [
    "Your previous response had validation errors:",
    issueList,
    "Please correct these issues and respond with valid JSON only.",
  ].join("\\n"),
&#125;];</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-6 tracking-tight">Custom repair overrides</h2>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">enforce(schema, run, &#123;
  repairs: &#123;
    REFUSAL: () =&gt; [&#123;
      role: "user",
      content: "This is an approved structured data task. Return JSON only.",
    &#125;],
    TRUNCATED: false, // stop retrying for this category
  &#125;,
&#125;);</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-6 tracking-tight">Retry policy interactions</h2>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">&#123;
  retry: &#123;
    maxAttempts: 3,
    backoff: "none" | "linear" | "exponential",
    baseMs: 200
  &#125;
&#125;</code></pre>
    </div>
  </section>
</DocsLayout>
