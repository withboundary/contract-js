---
import DocsLayout from "../layouts/DocsLayout.astro";
---

<DocsLayout title="Examples — llm-contract" description="Before/after and runnable examples for extraction, classification, and routing-style tasks.">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-12">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight"><span class="gradient-text">Examples</span></h1>
    <p class="text-zinc-400 text-lg max-w-3xl">Patterns that show what changes when you wrap LLM output with a contract boundary.</p>
    <div class="flex flex-wrap gap-3 mt-6 text-sm">
      <a href="#minimal" class="glass rounded-lg px-3 py-1.5 text-accent card-hover">Minimal</a>
      <a href="#extraction" class="glass rounded-lg px-3 py-1.5 text-accent card-hover">Extraction</a>
      <a href="#classification" class="glass rounded-lg px-3 py-1.5 text-accent card-hover">Classification</a>
      <a href="#routing" class="glass rounded-lg px-3 py-1.5 text-accent card-hover">Routing-style</a>
    </div>
  </section>

  <section id="minimal" class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Minimal example</h2>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">const result = await enforce(schema, async (attempt) =&gt; &#123;
  const res = await openai.responses.create(&#123;
    model: "gpt-4.1",
    input: [
      &#123; role: "system", content: attempt.instructions &#125;,
      &#123; role: "user", content: input &#125;,
      ...attempt.repairs,
    ],
  &#125;);
  return res.output_text;
&#125;);</code></pre>
    </div>
  </section>

  <section id="extraction" class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Extraction example</h2>
    <p class="text-zinc-400 mb-6">Invoice extraction with math invariants and typed results.</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">invariants: [
  (d) => Math.abs(d.subtotal + d.tax - d.total) < 0.01
    || `subtotal (&#36;&#123;d.subtotal&#125;) + tax (&#36;&#123;d.tax&#125;) != total (&#36;&#123;d.total&#125;)`,
]</code></pre>
    </div>
  </section>

  <section id="classification" class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Classification example</h2>
    <p class="text-zinc-400 mb-6">Enum-constrained ticket classification with bounded arrays.</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">const Ticket = z.object(&#123;
  category: z.enum(["bug", "feature", "question", "billing"]),
  priority: z.enum(["low", "medium", "high", "critical"]),
  tags: z.array(z.string()).max(5),
&#125;);</code></pre>
    </div>
  </section>

  <section id="routing" class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Routing-style example</h2>
    <p class="text-zinc-400 mb-6">Use confidence and invariant gates to make downstream routing deterministic.</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">invariants: [
  (d) => d.confidence > 0.5 || `confidence too low: &#36;&#123;d.confidence&#125;`,
]</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06]">
    <h2 class="text-2xl font-bold text-white mb-6 tracking-tight">Runnable examples</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href="https://github.com/operatorstack/llm-contract/blob/main/examples/extraction.ts" class="glass rounded-xl p-4 card-hover" target="_blank">
        <p class="text-white text-sm font-medium">extraction.ts</p><p class="text-zinc-500 text-sm">Invoice extraction with invariants</p>
      </a>
      <a href="https://github.com/operatorstack/llm-contract/blob/main/examples/classification.ts" class="glass rounded-xl p-4 card-hover" target="_blank">
        <p class="text-white text-sm font-medium">classification.ts</p><p class="text-zinc-500 text-sm">Ticket classification</p>
      </a>
      <a href="https://github.com/operatorstack/llm-contract/blob/main/examples/scoring.ts" class="glass rounded-xl p-4 card-hover" target="_blank">
        <p class="text-white text-sm font-medium">scoring.ts</p><p class="text-zinc-500 text-sm">Scoring constraints</p>
      </a>
    </div>
  </section>
</DocsLayout>
