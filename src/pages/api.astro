---
import DocsLayout from "../layouts/DocsLayout.astro";
---

<DocsLayout title="Core API — llm-contract" description="Reference for defineContract, enforce, grouped options, attempt context/events, and primitive exports.">
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-12">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight"><span class="gradient-text">Core API</span></h1>
    <p class="text-zinc-400 text-lg max-w-3xl">
      Full function signatures, parameters, and return types. Start with
      <code class="text-zinc-300 bg-surface px-1 py-0.5 rounded text-sm border border-border">defineContract</code>.
      Use <code class="text-zinc-300 bg-surface px-1 py-0.5 rounded text-sm border border-border">enforce</code>
      when you need a one-off call.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">defineContract</h2>
    <p class="text-zinc-400 mb-6">Primary API for reusable contract policies.</p>
    <div class="glass rounded-xl p-5 mb-6">
      <pre><code class="language-typescript">function defineContract&lt;T&gt;(&#123;
  schema: ZodType&lt;T&gt;,
  invariants?: Invariant&lt;T&gt;[],
  repairs?: Partial&lt;Record&lt;FailureCategory, RepairFn | false&gt;&gt;,
  retry?: &#123; maxAttempts?: number; backoff?: "none" | "linear" | "exponential"; baseMs?: number &#125;,
  instructions?: &#123; suffix?: string &#125;,
  onAttempt?: (event: AttemptEvent) =&gt; void,
&#125;): &#123;
  run(runFn, runtimeOptions?): Promise&lt;Result&lt;T&gt;&gt;
&#125;</code></pre>
    </div>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">const contract = defineContract(&#123; schema, retry: &#123; maxAttempts: 4 &#125; &#125;);
const result = await contract.run(async (attempt) =&gt; &#123;
  return llmCall(attempt.instructions, attempt.repairs);
&#125;);</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">enforce</h2>
    <p class="text-zinc-400 mb-6">Convenience wrapper that delegates to <code class="text-zinc-300 bg-surface px-1 py-0.5 rounded text-sm border border-border">defineContract(...).run(...)</code>.</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">function enforce&lt;T&gt;(
  schema: ZodType&lt;T&gt;,
  runFn: (attempt: AttemptContext) =&gt; Promise&lt;string | null&gt;,
  options?: ContractOptions&lt;T&gt;,
): Promise&lt;Result&lt;T&gt;&gt;</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">AttemptContext</h2>
    <div class="glass rounded-xl p-5 mb-6">
      <pre><code class="language-typescript">&#123;
  instructions: string;
  repairs: Message[];
  number: number;
  previousError?: ContractError;
  previousCategory?: FailureCategory;
&#125;</code></pre>
    </div>
    <h3 class="text-lg font-semibold text-white mb-3">Result&lt;T&gt;</h3>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">type Result&lt;T&gt; =
  | &#123; ok: true; data: T; attempts: number; raw: string; durationMS: number &#125;
  | &#123; ok: false; error: ContractError &#125;;</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Grouped options</h2>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">&#123;
  invariants?: Invariant&lt;T&gt;[];
  repairs?: Partial&lt;Record&lt;FailureCategory, RepairFn | false&gt;&gt;;
  retry?: &#123;
    maxAttempts?: number; // default 3
    backoff?: "none" | "linear" | "exponential";
    baseMs?: number; // default 200
  &#125;;
  instructions?: &#123; suffix?: string &#125;;
  logger?: ContractLogger&lt;T&gt;;
  debug?: boolean;
  onAttempt?: (event: AttemptEvent) =&gt; void;
&#125;</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Debug logger</h2>
    <p class="text-zinc-400 mb-6">Use <code class="text-zinc-300 bg-surface px-1 py-0.5 rounded text-sm border border-border">debug: true</code> for built-in console trace output, or pass a custom logger.</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">enforce(schema, run, &#123;
  debug: true,
&#125;);

enforce(schema, run, &#123;
  logger: createConsoleLogger(&#123; showCleanedOutput: true &#125;),
&#125;);</code></pre>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-14 border-t border-white/[0.06] fade-up">
    <h2 class="text-2xl font-bold text-white mb-2 tracking-tight">Primitive exports (reference)</h2>
    <p class="text-zinc-400 mb-6">Use primitives when integrating with custom pipelines:</p>
    <div class="glass rounded-xl p-5">
      <pre><code class="language-typescript">clean(raw)
verify(data, schema, invariants?)
classify(raw, cleaned)
repair(detail, repairs?)
select(state, schema)
instructions(schema)</code></pre>
    </div>
    <p class="text-zinc-500 text-sm mt-4">
      For conceptual behavior of these steps, see <a href="how-it-works" class="text-accent hover:text-accent-blue transition">How It Works</a>.
    </p>
  </section>
</DocsLayout>
