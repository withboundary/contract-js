{
  "name": "@withboundary/contract",
  "version": "0.0.0",
  "description": "Make LLM outputs correct, not just valid. Schema + rules + auto-repair.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@changesets/cli": "^2.29.8",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "llm",
    "structured-output",
    "correctness",
    "validation",
    "openai",
    "anthropic",
    "zod",
    "json-schema",
    "contract",
    "rules",
    "repair",
    "retry",
    "boundary"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
