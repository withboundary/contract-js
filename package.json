{
  "name": "llm-contract",
  "version": "0.1.0",
  "description": "Typed contracts for LLM calls. Validate, repair, retry.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@changesets/cli": "^2.29.8",
    "astro": "^5.18.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "llm",
    "structured-output",
    "zod",
    "validation",
    "openai",
    "anthropic",
    "contract"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
