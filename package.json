{
  "name": "@withboundary/contract",
  "version": "1.5.1",
  "description": "Make LLM outputs correct, not just valid. Schema + rules + auto-repair.",
  "keywords": [
    "anthropic",
    "boundary",
    "contract",
    "correctness",
    "json-schema",
    "llm",
    "openai",
    "repair",
    "retry",
    "rules",
    "structured-output",
    "validation",
    "zod"
  ],
  "homepage": "https://withboundary.com",
  "bugs": {
    "url": "https://github.com/withboundary/contract-js/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/withboundary/contract-js.git"
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "EXAMPLES.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.0.0",
    "zod-v3": "npm:zod@^3.25.76"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
