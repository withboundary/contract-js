{
  "name": "@withboundary/contract",
  "version": "1.3.0",
  "description": "Make LLM outputs correct, not just valid. Schema + rules + auto-repair.",
  "repository": {
    "type": "git",
    "url": "https://github.com/withboundary/contract-js.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openai": {
      "import": "./dist/providers/openai.js",
      "types": "./dist/providers/openai.d.ts"
    },
    "./anthropic": {
      "import": "./dist/providers/anthropic.js",
      "types": "./dist/providers/anthropic.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/providers/openai.ts src/providers/anthropic.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30",
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@changesets/cli": "^2.29.8",
    "openai": "^6.34.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "llm",
    "structured-output",
    "correctness",
    "validation",
    "openai",
    "anthropic",
    "zod",
    "json-schema",
    "contract",
    "rules",
    "repair",
    "retry",
    "boundary"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
