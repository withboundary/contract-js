{
  "name": "@withboundary/contract",
  "version": "1.5.0",
  "description": "Make LLM outputs correct, not just valid. Schema + rules + auto-repair.",
  "repository": {
    "type": "git",
    "url": "https://github.com/withboundary/contract-js.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "zod": "^4.0.0",
    "zod-v3": "npm:zod@^3.25.76"
  },
  "keywords": [
    "llm",
    "structured-output",
    "correctness",
    "validation",
    "openai",
    "anthropic",
    "zod",
    "json-schema",
    "contract",
    "rules",
    "repair",
    "retry",
    "boundary"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
